<Window x:Class="LLMUninstaller.Gui.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Height="420" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <Image Source="Assets/app-icon.png" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock x:Name="TitleText" Text="LLM Uninstaller"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Margin="0,6,0,20"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="SourceLabel" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Margin="0,0,0,14" Foreground="{StaticResource AccentBrush}">
                <Hyperlink x:Name="SourceLink" NavigateUri="https://github.com/Marfa/LLM_Uninstaller"
                           Foreground="{StaticResource AccentBrush}" RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/Marfa/LLM_Uninstaller
                </Hyperlink>
            </TextBlock>

            <TextBlock x:Name="DonateLabel" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Margin="0,0,0,10" Foreground="{StaticResource AccentBrush}">
                <Hyperlink x:Name="DonateLink" NavigateUri="https://www.donationalerts.com/r/themarfa"
                           Foreground="{StaticResource AccentBrush}" RequestNavigate="Hyperlink_RequestNavigate">
                    donationalerts.com/r/themarfa
                </Hyperlink>
            </TextBlock>

            <TextBlock x:Name="CryptoLabel" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Margin="0,0,0,24" Foreground="{StaticResource AccentBrush}">
                <Hyperlink x:Name="CryptoLink" NavigateUri="https://nowpayments.io/donation/themarfa"
                           Foreground="{StaticResource AccentBrush}" RequestNavigate="Hyperlink_RequestNavigate">
                    https://nowpayments.io/donation/themarfa
                </Hyperlink>
            </TextBlock>

            <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"
                    Padding="24,8" HorizontalAlignment="Center"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </ScrollViewer>
</Window>
