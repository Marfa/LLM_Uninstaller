<Window x:Class="LLMUninstaller.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLM Uninstaller"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        Icon="Assets/app.ico"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="HeaderTitle" Text="LLM Uninstaller"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="HeaderSubtitle"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="LanguageButton" Click="LanguageButton_Click"
                        Padding="10,6" Margin="0,0,8,0"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                        BorderThickness="0" Cursor="Hand" MinWidth="40"/>
                <Button x:Name="AboutButton" Click="AboutButton_Click"
                        Padding="12,6"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="ScanButton" Click="ScanButton_Click"
                    Padding="16,8" Margin="0,0,8,0"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="ExportCsvButton" Click="ExportCsvButton_Click"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                    BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
            <CheckBox x:Name="PermanentDeleteCheckBox"
                      IsChecked="False" VerticalAlignment="Center"
                      Focusable="True"
                      Foreground="{StaticResource TextBrush}" Margin="16,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="ModelsGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource SurfaceBrush}"
                  Foreground="{StaticResource TextBrush}"
                  RowBackground="{StaticResource SurfaceBrush}"
                  AlternatingRowBackground="#323248"
                  BorderBrush="#3F3F5A" BorderThickness="1"
                  PreviewMouseLeftButtonDown="ModelsGrid_PreviewMouseLeftButtonDown">
            <DataGrid.Columns>
                <DataGridTemplateColumn x:Name="ColSelect" Width="46" MinWidth="40" CanUserSort="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllCheckBox"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Checked="SelectAllCheckBox_Changed"
                                  Unchecked="SelectAllCheckBox_Changed"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Checked="RowCheckBox_Changed"
                                      Unchecked="RowCheckBox_Changed"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn x:Name="ColName" Width="180" MinWidth="80" SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn x:Name="ColSize" Binding="{Binding FormattedSize}" SortMemberPath="SizeBytes" Width="90" MinWidth="70"/>
                <DataGridTextColumn x:Name="ColType" Binding="{Binding TypeDisplay}" SortMemberPath="Type" Width="90" MinWidth="70"/>
                <DataGridTextColumn x:Name="ColApp" Binding="{Binding OwnerApplication}" SortMemberPath="OwnerApplication" Width="130" MinWidth="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding OwnerApplication}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColModified" Binding="{Binding LastModifiedDisplay}" SortMemberPath="LastModifiedTime" Width="140" MinWidth="100"/>
                <DataGridTemplateColumn x:Name="ColPath" Width="*" MinWidth="140" SortMemberPath="FullPath">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FullPath}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FullPath}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Click="OpenFolderButton_Click"
                                        Tag="{Binding FullPath}"
                                        Padding="6,2"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="14"
                                        Foreground="{StaticResource AccentBrush}"
                                        Content="&#xE838;"
                                        ToolTip="{DynamicResource OpenFolderToolTip}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource MutedBrush}" FontSize="12"/>
            <ProgressBar x:Name="ScanProgress" Height="4" Margin="0,6,0,0"
                         Visibility="Collapsed" Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}" FontSize="13"/>
            <Button x:Name="DeleteButton" Grid.Column="1"
                    Click="DeleteButton_Click"
                    Padding="20,10"
                    Background="{StaticResource DangerBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
